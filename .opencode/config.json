{
  "agents": {
    "web": {
      "path": ".opencode/agent/web.md",
      "description": "Frontend modifications to both websites"
    },
    "content": {
        "path": ".opencode/agent/content.md",
        "description": "Text content, copywriting, and translations"
    },
    "soul": {
        "path": ".opencode/soul/agent.md",
        "description": "Monitoring and health checks for the project"
    }
},
"defaultAgent": "web",
  "project": {
    "name": "Ludvik-Solar",
    "type": "static-website",
    "languages": ["html", "css", "js"],
    "primaryLanguage": "cs"
  },
  "mcp": {
    "servers": {
      "filesystem": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "."]
      },
      "everything": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-everything"]
      }
    }
  }
}