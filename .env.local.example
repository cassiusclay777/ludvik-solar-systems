# Google Maps / Solar API – zkopíruj do .env.local a doplň svůj klíč
# .env.local je v .gitignore a nesmí obsahovat reálné klíče v repozitáři
#
# Next.js: použije process.env.NEXT_PUBLIC_GOOGLE_MAPS_API_KEY automaticky.
# Statický HTML: před načtením stránky nastav window.__GOOGLE_MAPS_API_KEY__ (např. z build skriptu nebo serveru).

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_key_here
